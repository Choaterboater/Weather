// Copy this file to `Secrets.xcconfig` (gitignored) and fill in your token.
// Then in Xcode set the target/project's config file to Secrets.xcconfig
// (Project ▸ Info ▸ Configurations), or add the setting under Build Settings.
//
// Any unset value just disables that feature — everything else still works.

// AI-generated lure art (fallback when no real product is found):
REPLICATE_API_TOKEN = r8_your_token_here

// Real product photos + buy links via Amazon Product Advertising API.
// Requires an Amazon Associates account. The partner tag is your store ID.
AMAZON_ACCESS_KEY = your_access_key
AMAZON_SECRET_KEY = your_secret_key
AMAZON_PARTNER_TAG = yourtag-20

// Real product photos + buy links via the eBay Browse API.
// Free eBay developer keys; the campaign ID is your eBay Partner Network ID.
EBAY_CLIENT_ID = your_ebay_app_id
EBAY_CLIENT_SECRET = your_ebay_cert_id
EBAY_CAMPAIGN_ID = your_epn_campaign_id

// Tackle Warehouse / Bass Pro / FishUSA have no live product API — they're
// reachable via the in-app store picker as search links (wrap with your
// affiliate-network deep links if you have them).
