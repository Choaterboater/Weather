// Copy this file to `Secrets.xcconfig` (gitignored) and fill in your token.
// Then in Xcode set the target/project's config file to Secrets.xcconfig
// (Project ▸ Info ▸ Configurations), or add the setting under Build Settings.
//
// Without a token, image generation is simply disabled — everything else works.

REPLICATE_API_TOKEN = r8_your_token_here
