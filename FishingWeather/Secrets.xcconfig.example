// Copy this file to `Secrets.xcconfig` (gitignored) and fill in your token.
// The committed AppConfig.xcconfig (wired in by project.yml) includes it
// automatically when present — no manual Xcode step needed.
//
// Any unset value just disables that feature — everything else still works.

// AI-generated lure art (fallback when no real product is found):
REPLICATE_API_TOKEN = r8_your_token_here

// Real product photos + buy links via Amazon Product Advertising API.
// Requires an Amazon Associates account. The partner tag is your store ID.
AMAZON_ACCESS_KEY = your_access_key
AMAZON_SECRET_KEY = your_secret_key
AMAZON_PARTNER_TAG = yourtag-20

// Real product photos + buy links via the eBay Browse API.
// Free eBay developer keys; the campaign ID is your eBay Partner Network ID.
EBAY_CLIENT_ID = your_ebay_app_id
EBAY_CLIENT_SECRET = your_ebay_cert_id
EBAY_CAMPAIGN_ID = your_epn_campaign_id

// Tackle Warehouse / Bass Pro / FishUSA have no live product API — they're
// reachable via the in-app store picker as search links, which get wrapped in
// your affiliate-network deep link when you supply a template.
//
// IMPORTANT: affiliate templates are full URLs and contain "//", which xcconfig
// treats as a comment — so DON'T put them here. Instead paste the literal
// template into Info.plist (TackleWarehouseAffiliateTemplate / BassProAffiliate-
// Template / FishUSAAffiliateTemplate), using {url} where the destination goes.
// These IDs aren't secret (they appear in every affiliate link you publish).
//
// AvantLink example value to paste into Info.plist:
//   https://www.avantlink.com/click.php?tt=cl&mi=1234&pw=5678&url={url}
// Impact example (advertiser vanity domain):
//   https://brand.sjv.io/c/AFFID/CAMPID?u={url}

// YouTube Data API v3 key for local videos / tutorials
YOUTUBE_API_KEY = your_youtube_api_key_here
